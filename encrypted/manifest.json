{
  "manifest_version": 3,
  "name": "PII Guard (Obfuscate)",
  "version": "1.0.0",
  "description": "Redacts sensitive strings in outgoing requests (FormData, fetch, XHR).",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PII Guard - Redacting PII"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js", "page_inject.js"],
      "run_at": "document_start"
    }
  ]
}
